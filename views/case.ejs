<%- include('partials/header') %>
<%
  const TABS = [
    { id: 'purchase',    label: 'Køb' },
    { id: 'financing',   label: 'Finansiering' },
    { id: 'operating',   label: 'Drift & Udlejning' },
    { id: 'renovations', label: 'Renovering' },
    { id: 'summary',     label: 'Opsummering' },
  ];
%>
<%- include('partials/navbar') %>

<div class="topbar">
  <a href="/properties/<%= property.id %>" class="muted"><- <%= property.address %></a>
  <div class="actions">
    <button type="button" class="btn small" data-modal-open="#modal-duplicate">Dupliker</button>
    <form method="POST" action="/cases/<%= investmentCase.id %>/delete" style="display:inline" data-confirm="Slet denne investeringscase?">
      <button type="submit" class="btn link danger">Slet case</button>
    </form>
  </div>
</div>

<div class="page">
  <h1><%= investmentCase.name %></h1>

  <% if (flashSuccess) { %><div class="alert success"><%= flashSuccess %></div><% } %>
  <% if (flashError) { %><div class="alert error"><%= flashError %></div><% } %>

  <div class="tabs">
    <% TABS.forEach((t) => { %>
      <a href="/cases/<%= investmentCase.id %>?tab=<%= t.id %>"
         class="<%= t.id === tab ? 'active' : '' %>"><%= t.label %></a>
    <% }) %>
  </div>

  <% if (tab === 'purchase') { %>
    <%- include('partials/case/purchase') %>
  <% } else if (tab === 'financing') { %>
    <%- include('partials/case/financing') %>
  <% } else if (tab === 'operating') { %>
    <%- include('partials/case/operating') %>
  <% } else if (tab === 'renovations') { %>
    <%- include('partials/case/renovations') %>
  <% } else if (tab === 'summary') { %>
    <%- include('partials/case/summary') %>
  <% } %>
</div>

<div class="modal-overlay" id="modal-duplicate">
  <div class="modal">
    <header>
      <h2>Dupliker case</h2>
      <button type="button" class="close" data-modal-close>x</button>
    </header>
    <form method="POST" action="/cases/<%= investmentCase.id %>/duplicate">
      <div class="body">
        <div class="field">
          <label for="duplicate-name">Navn på kopi</label>
          <input type="text" id="duplicate-name" name="name" value="<%= investmentCase.name %> (kopi)" required>
        </div>
      </div>
      <footer>
        <button type="button" class="btn" data-modal-close>Annuller</button>
        <button type="submit" class="btn primary">Dupliker</button>
      </footer>
    </form>
  </div>
</div>

<script src="/js/case-forms.js" defer></script>
<%- include('partials/footer') %>
