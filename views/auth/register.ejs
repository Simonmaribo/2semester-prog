<%- include('../partials/header') %>
<div class="auth">
  <div class="card">
    <h1>Opret konto</h1>
    <% if (error) { %><div class="alert error"><%= error %></div><% } %>
    <form method="POST" action="/auth/register">
      <div class="field">
        <label for="name">Navn</label>
        <input type="text" id="name" name="name" required minlength="2">
      </div>
      <div class="field">
        <label for="email">Email</label>
        <input type="email" id="email" name="email" required>
      </div>
      <div class="field">
        <label for="password">Password (min. 8 tegn)</label>
        <input type="password" id="password" name="password" required minlength="8">
      </div>
      <button type="submit" class="btn primary" style="width:100%">Opret konto</button>
    </form>
    <p class="muted" style="text-align:center; margin-top:16px">Har du allerede en konto? <a href="/auth/login" style="color:#06f">Log ind</a></p>
  </div>
</div>
<%- include('../partials/footer') %>
