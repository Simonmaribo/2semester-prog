<%- include('partials/header') %>
<%- include('partials/navbar', { activePage: 'properties' }) %>

<div class="topbar">
  <a href="/properties" class="muted"><- Ejendomme</a>
  <div class="actions">
    <button class="btn primary" onclick="document.getElementById('modal-case').classList.add('active')">+ Ny case</button>
    <form method="POST" action="/properties/<%= property.id %>/delete" style="display:inline" onsubmit="return confirm('Slet ejendom og alle tilknyttede cases?')">
      <button type="submit" class="btn link danger">Slet ejendom</button>
    </form>
  </div>
</div>

<div class="page">
  <div class="grid-2">
    <div class="card">
      <h2>Kortvisning</h2>
      <div class="map">
        <% if (aerialPhotoUrl) { %>
          <img src="<%= aerialPhotoUrl %>" alt="Luftfoto af <%= property.address %>">
        <% } else { %>
          <div class="placeholder">Ingen koordinater tilgængelige for denne ejendom.</div>
        <% } %>
      </div>
    </div>

    <div class="card">
      <h1><%= property.address %></h1>
      <div class="muted">
        <%= property.property_type || 'Ukendt type' %>
        <% if (property.build_year) { %> · Byggeår <%= property.build_year %><% } %>
        · Oprettet <%= new Date(property.created_at).toLocaleDateString('da-DK') %>
      </div>

      <table style="margin-top:14px">
        <tr><td>Boligareal</td><td class="right"><%= property.living_area ? property.living_area + ' m²' : '-' %></td></tr>
        <tr><td>Værelser</td><td class="right"><%= property.rooms || '-' %></td></tr>
        <tr><td>Byggeår</td><td class="right"><%= property.build_year || '-' %></td></tr>
        <tr><td>Type</td><td class="right"><%= property.property_type || '-' %></td></tr>
      </table>
    </div>
  </div>

  <div class="card">
    <h2>Investeringscases</h2>

    <% if (cases.length === 0) { %>
      <p class="muted">Ingen cases endnu.</p>
    <% } else { %>
      <table>
        <thead>
          <tr><th>Navn</th><th>Oprettet</th><th></th></tr>
        </thead>
        <tbody>
          <% for (const c of cases) { %>
            <tr>
              <td><%= c.name %></td>
              <td class="muted"><%= new Date(c.created_at).toLocaleDateString('da-DK') %></td>
              <td class="right">
                <a href="/cases/<%= c.id %>" class="btn small">Rediger</a>
                <a href="/simulation/<%= c.id %>" class="btn small primary">Simulering</a>
              </td>
            </tr>
          <% } %>
        </tbody>
      </table>
    <% } %>
  </div>
</div>

<div class="modal-overlay" id="modal-case">
  <div class="modal">
    <header>
      <h2>Ny investeringscase</h2>
      <button class="close" onclick="document.getElementById('modal-case').classList.remove('active')">x</button>
    </header>
    <form method="POST" action="/cases">
      <div class="body">
        <input type="hidden" name="property_id" value="<%= property.id %>">
        <div class="field">
          <label for="case-name">Navn</label>
          <input type="text" id="case-name" name="name" required placeholder="Fx Scenarie 1 - 5% udbetaling">
        </div>
        <div class="field">
          <label for="case-description">Beskrivelse</label>
          <textarea id="case-description" name="description" rows="3"></textarea>
        </div>
      </div>
      <footer>
        <button type="button" class="btn" onclick="document.getElementById('modal-case').classList.remove('active')">Annuller</button>
        <button type="submit" class="btn primary">Opret case</button>
      </footer>
    </form>
  </div>
</div>

<%- include('partials/footer') %>
