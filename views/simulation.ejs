<%- include('partials/header') %>
<%- include('partials/navbar', { activePage: '' }) %>

<div class="topbar">
  <a href="/cases/<%= investmentCase.id %>" class="muted"><- <%= investmentCase.name %></a>
</div>

<div class="page">
  <h1>Simulering</h1>
  <p class="muted">
    <%= property.address %> · <%= investmentCase.simulation_years %> år · <%= investmentCase.annual_appreciation_pct %>% værdistigning p.a.
  </p>

  <% const lastYear = yearlyResults[yearlyResults.length - 1]; %>

  <div class="grid-auto" style="margin-top:14px">
    <div class="card">
      <div class="muted">Udbetaling (inkl. omk.)</div>
      <strong><%= totalInitialInvestment.toLocaleString('da-DK') %> kr</strong>
    </div>
    <div class="card">
      <div class="muted">Ejendomsværdi (år <%= lastYear.year %>)</div>
      <strong><%= lastYear.propertyValue.toLocaleString('da-DK') %> kr</strong>
    </div>
    <div class="card">
      <div class="muted">Egenkapital (år <%= lastYear.year %>)</div>
      <strong><%= lastYear.equity.toLocaleString('da-DK') %> kr</strong>
    </div>
    <div class="card">
      <div class="muted">Kumulativt cashflow</div>
      <strong class="<%= lastYear.cumulativeCashflow >= 0 ? 'positive' : 'negative' %>"><%= lastYear.cumulativeCashflow.toLocaleString('da-DK') %> kr</strong>
    </div>
    <div class="card">
      <div class="muted">Årligt afkast (ROI)</div>
      <strong><%= lastYear.roi %>%</strong>
    </div>
    <div class="card">
      <div class="muted">Afkastgrad</div>
      <strong><%= lastYear.afkastgrad %>%</strong>
    </div>
  </div>

  <div class="grid-2">
    <div class="card"><h2>Ejendomsværdi, Gæld & Egenkapital</h2><canvas id="equityChart"></canvas></div>
    <div class="card"><h2>Årligt cashflow</h2><canvas id="cashflowChart"></canvas></div>
  </div>

  <div class="card">
    <h2>År-for-år oversigt</h2>
    <div class="scroll-x">
      <table class="nowrap">
        <thead>
          <tr>
            <th>År</th>
            <th>Ejendomsværdi</th>
            <th>Gæld</th>
            <th>Egenkapital</th>
            <th>Rente</th>
            <th>Afdrag</th>
            <th>Drift</th>
            <th>Lejeindtægt</th>
            <th>Renovering</th>
            <th>Cashflow</th>
            <th>Kum. CF</th>
            <th>ROI %/år</th>
          </tr>
        </thead>
        <tbody>
          <% for (const yr of yearlyResults) { %>
            <tr>
              <td><strong><%= yr.year %></strong></td>
              <td><%= yr.propertyValue.toLocaleString('da-DK') %></td>
              <td><%= yr.totalDebt.toLocaleString('da-DK') %></td>
              <td><%= yr.equity.toLocaleString('da-DK') %></td>
              <td><%= yr.annualInterestPaid.toLocaleString('da-DK') %></td>
              <td><%= yr.annualPrincipalPaid.toLocaleString('da-DK') %></td>
              <td><%= yr.annualOperatingCosts.toLocaleString('da-DK') %></td>
              <td><%= yr.annualRentalIncome.toLocaleString('da-DK') %></td>
              <td><%= yr.annualRenovationCosts > 0 ? yr.annualRenovationCosts.toLocaleString('da-DK') : '-' %></td>
              <td class="<%= yr.annualCashflow >= 0 ? 'positive' : 'negative' %>"><%= yr.annualCashflow.toLocaleString('da-DK') %></td>
              <td class="<%= yr.cumulativeCashflow >= 0 ? 'positive' : 'negative' %>"><%= yr.cumulativeCashflow.toLocaleString('da-DK') %></td>
              <td><%= yr.roi %>%</td>
            </tr>
          <% } %>
        </tbody>
      </table>
    </div>
  </div>
</div>

<script src="https://cdn.jsdelivr.net/npm/chart.js@4"></script>
<script>var simulationData = <%- JSON.stringify(yearlyResults) %>;</script>
<script type="module" src="/js/charts.js"></script>
<%- include('partials/footer') %>
