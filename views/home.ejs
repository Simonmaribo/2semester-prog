<%- include('partials/header') %>
<%- include('partials/navbar', { activePage: 'properties' }) %>

<div class="topbar">
  <div>Mine ejendomme</div>
  <button class="btn primary" onclick="document.getElementById('modal-create').classList.add('active')">+ Opret ejendom</button>
</div>

<div class="page">
  <% if (error) { %><div class="alert error"><%= error %></div><% } %>
  <% if (success) { %><div class="alert success"><%= success %></div><% } %>

  <% if (properties.length === 0) { %>
    <p class="muted">Du har ingen ejendomme endnu. Klik "Opret ejendom" for at komme i gang.</p>
  <% } else { %>
    <div class="grid-auto">
      <% for (const prop of properties) { %>
        <a href="/properties/<%= prop.id %>" class="card-link">
          <h3><%= prop.address %></h3>
          <div class="muted">
            <%= prop.property_type || 'Ukendt type' %>
            <% if (prop.build_year) { %> · Byggeår <%= prop.build_year %><% } %>
            <% if (prop.living_area) { %> · <%= prop.living_area %> m²<% } %>
          </div>
          <div class="muted" style="font-size:11px; margin-top:6px">
            <%= prop.case_count || 0 %> cases · <%= new Date(prop.created_at).toLocaleDateString('da-DK') %>
          </div>
        </a>
      <% } %>
    </div>
  <% } %>
</div>

<div class="modal-overlay" id="modal-create">
  <div class="modal">
    <header>
      <h2>Opret ejendom</h2>
      <button class="close" onclick="document.getElementById('modal-create').classList.remove('active')">x</button>
    </header>
    <div class="body">
      <div class="autocomplete">
        <div class="field">
          <label for="address-input">Søg adresse</label>
          <div class="row">
            <input type="text" id="address-input" placeholder="Fx Vestergade 10, 1456 København K" autocomplete="off">
            <button type="button" id="address-search-btn" class="btn primary shrink">Søg</button>
          </div>
          <div id="autocomplete-results" class="results"></div>
        </div>

        <form method="POST" action="/properties" id="create-property-form" style="display: none;">
          <input type="hidden" name="address" id="selected-address">
          <input type="hidden" name="dawa_address_id" id="selected-dawa-id">
          <input type="hidden" name="latitude" id="selected-lat">
          <input type="hidden" name="longitude" id="selected-lng">
          <input type="hidden" name="property_type" id="selected-type">
          <input type="hidden" name="build_year" id="selected-year">
          <input type="hidden" name="living_area" id="selected-area">
          <input type="hidden" name="rooms" id="selected-rooms">
          <div id="property-preview"></div>
          <div style="display:flex; justify-content:flex-end; gap:8px; margin-top:14px">
            <button type="button" class="btn" onclick="document.getElementById('modal-create').classList.remove('active')">Annuller</button>
            <button type="submit" class="btn primary">Opret ejendom</button>
          </div>
        </form>
      </div>
    </div>
  </div>
</div>

<script type="module" src="/js/addressSearch.js"></script>
<%- include('partials/footer') %>
