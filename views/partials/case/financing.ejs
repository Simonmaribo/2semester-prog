<form method="POST" action="/cases/<%= investmentCase.id %>/financing" class="tab-content">
  <div class="intro">
    <h2>Finansiering</h2>
    <p class="muted">Opsæt dine lån. Du kan fjerne banklånet og justere beløbene efter behov.</p>
  </div>

  <div class="inputs">
    <div class="inputs-row header" style="grid-template-columns: 2fr 1.5fr 0.8fr 0.8fr 0.8fr 1fr 36px">
      <span>Betegnelse</span>
      <span>Beløb</span>
      <span>Rente %</span>
      <span>Løbetid</span>
      <span>Afdragsfri (år)</span>
      <span>Type</span>
      <span></span>
    </div>
    <div id="loans-list">
      <% loansForForm.forEach((loan, i) => { %>
        <div class="inputs-row" style="grid-template-columns: 2fr 1.5fr 0.8fr 0.8fr 0.8fr 1fr 36px">
          <input type="text" name="loans[<%= i %>][label]" value="<%= loan.label %>" placeholder="Betegnelse">
          <input type="number" name="loans[<%= i %>][amount]" value="<%= loan.amount %>" min="0" placeholder="Beløb">
          <input type="number" name="loans[<%= i %>][interest_rate_pct]" value="<%= loan.interest_rate_pct %>" min="0" step="0.01" placeholder="Rente %">
          <input type="number" name="loans[<%= i %>][term_years]" value="<%= loan.term_years %>" min="1" max="50" placeholder="År">
          <input type="number" name="loans[<%= i %>][interest_only_years]" value="<%= loan.interest_only_years || 0 %>" min="0" max="30" placeholder="Afdragsfri (år)">
          <select name="loans[<%= i %>][loan_type]">
            <option value="fixed"<%= loan.loan_type === 'fixed' ? ' selected' : '' %>>Fast</option>
            <option value="variable"<%= loan.loan_type === 'variable' ? ' selected' : '' %>>Variabel</option>
          </select>
          <button type="button" class="remove">x</button>
        </div>
      <% }) %>
    </div>
  </div>

  <template id="loans-row-template">
    <div class="inputs-row" style="grid-template-columns: 2fr 1.5fr 0.8fr 0.8fr 0.8fr 1fr 36px">
      <input type="text" name="loans[INDEX][label]" placeholder="Betegnelse">
      <input type="number" name="loans[INDEX][amount]" value="0" min="0" placeholder="Beløb">
      <input type="number" name="loans[INDEX][interest_rate_pct]" value="3.5" min="0" step="0.01" placeholder="Rente %">
      <input type="number" name="loans[INDEX][term_years]" value="30" min="1" max="50" placeholder="År">
      <input type="number" name="loans[INDEX][interest_only_years]" value="0" min="0" max="30" placeholder="Afdragsfri (år)">
      <select name="loans[INDEX][loan_type]">
        <option value="fixed" selected>Fast</option>
        <option value="variable">Variabel</option>
      </select>
      <button type="button" class="remove">x</button>
    </div>
  </template>

  <button type="button" class="btn small" onclick="addRow('loans-list', 'loans-row-template')">+ Tilføj lån</button>

  <div class="footer">
    <button type="submit" class="btn primary">Gem & fortsæt -></button>
  </div>
</form>
