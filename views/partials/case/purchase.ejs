<form method="POST" action="/cases/<%= investmentCase.id %>/purchase" class="tab-content">
  <div class="intro">
    <h2>Køb & omkostninger</h2>
    <p class="muted">Angiv købsprisen og tilhørende omkostninger.</p>
  </div>

  <div class="row">
    <div class="field" style="flex:2">
      <label for="price">Ejendomspris (DKK)</label>
      <input type="number" id="price" name="purchase_price" value="<%= investmentCase.purchase_price %>" min="0" required>
    </div>
    <div class="field">
      <label for="simulation-years">Periode (år)</label>
      <input type="number" id="simulation-years" name="simulation_years" value="<%= investmentCase.simulation_years %>" min="1" max="50" required>
    </div>
    <div class="field">
      <label for="appreciation">Værdistigning (%/år)</label>
      <input type="number" id="appreciation" name="annual_appreciation_pct" value="<%= investmentCase.annual_appreciation_pct %>" step="0.01" required>
    </div>
  </div>

  <h3>Købsomkostninger</h3>
  <div class="inputs" id="costs-list">
    <% purchaseCostsForForm.forEach((cost, i) => { %>
      <div class="inputs-row" style="grid-template-columns: 2fr 1fr 36px">
        <input type="text" name="costs[<%= i %>][label]" value="<%= cost.label %>" placeholder="Beskrivelse">
        <input type="number" name="costs[<%= i %>][amount]" value="<%= cost.amount %>" min="0" placeholder="Beløb">
        <button type="button" class="remove">x</button>
      </div>
    <% }) %>
  </div>

  <template id="costs-row-template">
    <div class="inputs-row" style="grid-template-columns: 2fr 1fr 36px">
      <input type="text" name="costs[INDEX][label]" placeholder="Beskrivelse">
      <input type="number" name="costs[INDEX][amount]" value="0" min="0" placeholder="Beløb">
      <button type="button" class="remove">x</button>
    </div>
  </template>

  <button type="button" class="btn small" onclick="addRow('costs-list', 'costs-row-template')">+ Tilføj omkostning</button>

  <div class="footer">
    <button type="submit" class="btn primary">Gem & fortsæt -></button>
  </div>
</form>
